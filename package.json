{
    "name": "tienxin-productivity-assistant",
    "version": "1.3.2",
    "description": "添心生產力助手 - 員工生產力監測系統",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dev": "electron . --dev",
        "build": "electron-builder",
        "build:win": "electron-builder --win --x64"
    },
    "author": "添心室內裝修設計",
    "license": "UNLICENSED",
    "private": true,
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    },
    "dependencies": {
        "active-win": "^8.1.0",
        "electron-log": "^5.4.3",
        "electron-store": "^8.1.0",
        "electron-updater": "^6.7.3",
        "node-schedule": "^2.1.1",
        "sql.js": "^1.9.0",
        "uuid": "^9.0.0"
    },
    "build": {
        "appId": "com.tienxin.productivity-assistant",
        "productName": "TienxinAssistant",
        "asar": true,
        "compression": "maximum",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!dist/*",
            "!.cache/*",
            "!*.log",
            "!debug_log.txt",
            "!test_verification.js",
            "!verify_*.js",
            "!data/activities.db",
            "!.git/*",
            "!.vscode/*"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/icon.ico"
        },
        "nsis": {
            "oneClick": true,
            "allowToChangeInstallationDirectory": false,
            "shortcutName": "添心生產力助手",
            "installerLanguages": [
                "zh_TW"
            ],
            "language": "1028",
            "deleteAppDataOnUninstall": false
        },
        "publish": [
            {
                "provider": "github",
                "owner": "nephi4377",
                "repo": "liff-checkin"
            }
        ]
    }
}